---
import { Image } from 'astro:assets';
import { partners, type Partner } from '../data/partners';

type ImageModule = { default: ImageMetadata };
const logoModules = import.meta.glob<ImageModule>('../assets/images/partners/*.svg');

async function resolvePartner(p: Partner) {
	const mod = await logoModules[`../assets/images/partners/${p.logoFile}`]?.();
	return { ...p, src: mod!.default };
}

const resolved = await Promise.all(partners.map(resolvePartner));
const platinum = resolved.filter(p => p.tier === 'platinum');
const gold = resolved.filter(p => p.tier === 'gold');
const silver = resolved.filter(p => p.tier === 'silver');
const other = resolved.filter(p => p.tier === 'other');
const strategic = resolved.filter(p => p.tier === 'strategic');
const patron = resolved.filter(p => p.tier === 'patron');
---

<section class="partners-container">
	<div class="partners-header reveal">
		<h2>Ovogodišnji partneri</h2>
		<p>Iza svakog logotipa krije se tim koji traži baš tebe. Iskoristi priliku i upoznaj ih!</p>
	</div>

	<div class="tier-section reveal">
		<div class="tier-label">
			<span class="tier-label-text platinum-label">Platinum partneri</span>
		</div>
		<div class="platinum-partners reveal-stagger">
			{platinum.map(p => (
				<a href={p.url} target="_blank" rel="noopener" class={`partner-card platinum-card ${p.logoClass ?? ''}`}>
					<Image src={p.src} alt={`${p.name} logo`} />
				</a>
			))}
		</div>
	</div>

	{gold.length > 0 && (
		<div class="tier-section reveal">
			<div class="tier-label">
				<span class="tier-label-text gold-label">Zlatni partneri</span>
			</div>
			<div class="partners-grid reveal-stagger">
				{gold.map(p => (
					<div class={`partner-item ${p.logoClass ?? ''}`}>
						<a href={p.url} target="_blank" rel="noopener">
							<Image src={p.src} alt={`${p.name} logo`} />
						</a>
					</div>
				))}
			</div>
		</div>
	)}

	{silver.length > 0 && (
		<div class="tier-section reveal">
			<div class="tier-label">
				<span class="tier-label-text silver-label">Silver Partneri</span>
			</div>
			<div class="partners-grid reveal-stagger">
				{silver.map(p => (
					<div class="partner-item grid-card">
						<a href={p.url} target="_blank" rel="noopener">
							<Image src={p.src} alt={`${p.name} logo`} />
						</a>
					</div>
				))}
			</div>
		</div>
	)}

	{other.length > 0 && (
		<div class="tier-section reveal">
			<div class="tier-label">
				<span class="tier-label-text other-label">Ostali partneri</span>
			</div>
			<div class="partners-grid reveal-stagger">
				{other.map(p => (
					<div class="partner-item grid-card">
						<a href={p.url} target="_blank" rel="noopener">
							<Image src={p.src} alt={`${p.name} logo`} />
						</a>
					</div>
				))}
			</div>
		</div>
	)}

	{(strategic.length > 0 || patron.length > 0) && (
		<div class="bottom-section-partners reveal-stagger">
			{strategic.map(p => (
				<div class="partner-bottom">
					<h2>Strateški partneri:</h2>
					<a href={p.url} target="_blank" rel="noopener">
						<Image src={p.src} alt={`${p.name} logo`} />
					</a>
				</div>
			))}
			{patron.map(p => (
				<div class="partner-bottom">
					<h2>Pod pokroviteljstvom:</h2>
					<a href={p.url} target="_blank" rel="noopener">
						<Image src={p.src} alt={`${p.name} logo`} />
					</a>
				</div>
			))}
		</div>
	)}
</section>
