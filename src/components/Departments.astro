---
const departments = [
	{ name: 'Elektrotehnika', desc: 'Električni sustavi, automatika i energetika.' },
	{ name: 'Računarstvo', desc: 'Programiranje, mreže i računalni sustavi.' },
	{ name: 'Strojarstvo', desc: 'Mehanika, konstrukcija i industrijska postrojenja.' },
	{ name: 'Mehatronika', desc: 'Spoj strojarstva, elektronike i računarstva.' },
	{ name: 'Graditeljstvo', desc: 'Projektiranje, gradnja i infrastruktura.' },
	{ name: 'Informatika', desc: 'Digitalni sustavi, baze podataka i IT rješenja.' },
];

const rotations = [-18, -12, -6, 0, 6, 12, 18];
const translateY = [60, 30, 10, 0, 10, 30, 60];
const translateX = [80, 45, 18, 0, -18, -45, -80];
---

<section class="departments">
	<div class="dept-header reveal">
		<h2>Pridruži se <span>1500+ studenata</span><br />i lansiraj svoju karijeru!</h2>
		<p>Zašto doći? Jer 1500 studenata ne dolazi bez razloga. Tu je mjesto gdje se stvari stvarno pokreću — gdje upoznaš ljude koji ti mogu otvoriti vrata.</p>
	</div>

	<!-- Fan of cards -->
	<div class="dept-fan-wrapper reveal scale">
		<div class="dept-fan">
			{
				departments.map((d, i) => (
					<div class={`dept-card dept-card--${i}`}>
						<div class="dept-card-inner">
							<span class="dept-card-name">{d.name}</span>
							<span class="dept-card-desc">{d.desc}</span>
						</div>
					</div>
				))
			}
		</div>
	</div>

	<p class="dept-footer-text reveal">Industrije koje povezujemo i područja iz kojih dolaze studenti — pronađi gdje se ti uklapaš.</p>
</section>

<style>
	.departments {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--padding-top-bottom) var(--padding-side-main);
		background: var(--white);
		gap: 50px;
	}

	/* === Header === */
	.dept-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
		text-align: center;
	}

	.dept-header h2 {
		font-family: var(--font-main);
		font-size: var(--font-4xl);
		font-weight: 800;
		line-height: 110%;
		letter-spacing: 0.02em;
		color: var(--black);
	}

	.dept-header h2 span {
		color: var(--primary-yellow);
	}

	.dept-header p {
		font-family: var(--font-small);
		font-size: var(--font-md);
		font-weight: 600;
		line-height: 180%;
		opacity: 0.65;
		max-width: 745px;
		color: var(--black);
	}

	/* === Fan wrapper === */
	.dept-fan-wrapper {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.dept-fan {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		position: relative;
	}

	/* === Cards === */
	.dept-card {
		width: 200px;
		height: 200px;
		border-radius: 20px;
		flex-shrink: 0;
		position: relative;
		border: 2px solid rgba(255, 255, 255, 0.25);
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
		cursor: pointer;
		transition:
			border 0.25s ease,
			box-shadow 0.25s ease;
	}

	.dept-card--0,
	.dept-card--2,
	.dept-card--4 {
		background: linear-gradient(135deg, #1a1a1a, #0d0d0d);
	}
	.dept-card--1,
	.dept-card--3,
	.dept-card--5 {
		background: linear-gradient(135deg, #111111, #1f1f1f);
	}

	/* Transforms & z-index — left to right, rightmost highest */
	.dept-card--0 {
		transform: rotate(-18deg) translate(80px, 60px);
		z-index: 1;
	}
	.dept-card--1 {
		transform: rotate(-12deg) translate(45px, 30px);
		z-index: 2;
	}
	.dept-card--2 {
		transform: rotate(-6deg) translate(18px, 10px);
		z-index: 3;
	}
	.dept-card--3 {
		transform: rotate(0deg) translate(0px, 0px);
		z-index: 4;
	}
	.dept-card--4 {
		transform: rotate(6deg) translate(-18px, 10px);
		z-index: 5;
	}
	.dept-card--5 {
		transform: rotate(12deg) translate(-45px, 30px);
		z-index: 6;
	}

	.dept-card:hover {
		border: 2px solid var(--primary-yellow);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
		z-index: 20 !important;
	}

	/* Noise texture overlay for depth */
	.dept-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse at 85% 15%, rgba(234, 179, 8, 0.18) 0%, transparent 55%), radial-gradient(ellipse at 15% 85%, rgba(0, 0, 0, 0.4) 0%, transparent 55%);
		border-radius: inherit;
		pointer-events: none;
		z-index: 1;
	}

	.dept-card-name {
		font-family: var(--font-main);
		font-size: var(--font-lg);
		font-weight: 700;
		color: var(--primary-yellow);
		line-height: 110%;
		letter-spacing: 0.01em;
	}

	.dept-card-desc {
		font-family: var(--font-small);
		font-size: var(--font-sm);
		font-weight: 400;
		color: rgba(255, 255, 255, 0.55);
		line-height: 130%;
	}

	.dept-card-inner {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 16px;
		z-index: 2;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	/* === Footer text === */
	.dept-footer-text {
		font-family: var(--font-small);
		font-size: var(--font-md);
		font-weight: 600;
		line-height: 180%;
		opacity: 0.65;
		color: var(--black);
		text-align: center;
		max-width: 500px;
	}

	/* === Responsive === */
	@media (max-width: 1199px) {
		.dept-card {
			width: 155px;
			height: 155px;
		}
		.dept-card-name {
			font-size: var(--font-base);
		}
		.dept-card-desc {
			font-size: 11px;
		}
	}

	@media (max-width: 991px) {
		.dept-card {
			width: 150px;
			height: 150px;
		}
		.dept-card-name {
			font-size: var(--font-sm);
		}
		.dept-card-desc {
			font-size: 10px;
		}
		.dept-card-inner {
			padding: 10px;
			gap: 3px;
		}
	}

	@media (max-width: 850px) {
		.dept-header h2 {
			font-size: var(--font-3xl);
		}

		.dept-card {
			width: 140px;
			height: 140px;
			border-radius: 16px;
			flex-shrink: 0;
		}

		.dept-card-name {
			font-size: var(--font-sm);
		}

		.dept-card-desc {
			font-size: 11px;
		}

		.dept-card-inner {
			padding: 12px;
		}
	}

	@media (max-width: 500px) {
		.dept-header h2 {
			font-size: var(--font-2xl);
		}

		.dept-fan {
			gap: 10px;
		}

		.dept-card {
			width: 90px;
			height: 90px;
			border-radius: 14px;
		}

		.dept-card-name {
			font-size: 10px;
		}

		.dept-card-desc {
			font-size: 8px;
			line-height: 1.3;
		}

		.dept-card-inner {
			padding: 10px;
			gap: 3px;
		}
	}

	@media (max-width: 380px) {
		.dept-card {
			width: 90px;
			height: 90px;
			border-radius: 12px;
		}

		.dept-card-name {
			font-size: 10px;
		}

		.dept-card-desc {
			font-size: 9px;
		}

		.dept-card-inner {
			padding: 8px;
		}
	}
</style>
