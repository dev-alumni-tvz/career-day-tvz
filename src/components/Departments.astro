---
import { departments } from '../data/departments';
---

<section class="departments">
	<div class="dept-header reveal">
		<h2>Pridruži se <span>1500+ studenata</span><br />i lansiraj svoju karijeru!</h2>
		<p>Zašto doći? Jer 1500 studenata ne dolazi bez razloga. Tu je mjesto gdje se stvari stvarno pokreću — gdje upoznaš ljude koji ti mogu otvoriti vrata.</p>
	</div>

	<!-- Fan of cards -->
	<div class="dept-fan-wrapper reveal scale">
		<div class="dept-fan">
			{
				departments.map((d, i) => (
					<div class={`dept-card dept-card--${i}`} style={`background: ${d.gradient}`}>
						<div class="dept-card-inner">
							<span class="dept-card-name">{d.name}</span>
							<span class="dept-card-desc">{d.desc}</span>
						</div>
					</div>
				))
			}
		</div>
	</div>

	<p class="dept-footer-text reveal">Industrije koje povezujemo i područja iz kojih dolaze studenti — pronađi gdje se ti uklapaš.</p>
</section>

<style>
	.departments {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: var(--padding-top-bottom) var(--padding-side-main);
		background: var(--white);
		gap: 50px;
	}

	/* === Header === */
	.dept-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
		text-align: center;
	}

	.dept-header h2 {
		font-family: var(--font-main);
		font-size: var(--font-4xl);
		font-weight: 800;
		line-height: 110%;
		letter-spacing: 0.02em;
		color: var(--black);
	}

	.dept-header h2 span {
		color: var(--primary-yellow);
	}

	.dept-header p {
		font-family: var(--font-small);
		font-size: var(--font-md);
		font-weight: 600;
		line-height: 180%;
		opacity: 0.65;
		max-width: 745px;
		color: var(--black);
	}

	/* === Fan wrapper === */
	.dept-fan-wrapper {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.dept-fan {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		position: relative;
	}

	/* === Cards === */
	.dept-card {
		width: 200px;
		height: 200px;
		border-radius: 16px;
		flex-shrink: 0;
		position: relative;
		outline: 2px solid transparent;
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
		cursor: pointer;
		transition:
			outline-color 0.25s ease,
			box-shadow 0.25s ease;
	}

	.dept-card:hover {
		outline-color: rgba(255, 255, 255, 0.25);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
		z-index: 20 !important;
	}
	.dept-card-name {
		color: #ffffff;
	}

	.dept-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.2) 45%, transparent 100%);
		border-radius: inherit;
		pointer-events: none;
		z-index: 1;
	}

	.dept-card-desc {
		color: rgba(255, 255, 255, 0.75);
	}

	/* Transforms & z-index — left to right, rightmost highest */
	.dept-card--0 {
		transform: rotate(-18deg) translate(80px, 95px);
		z-index: 1;
	}
	.dept-card--1 {
		transform: rotate(-12deg) translate(45px, 38px);
		z-index: 2;
	}
	.dept-card--2 {
		transform: rotate(-6deg) translate(18px, 10px);
		z-index: 3;
	}
	.dept-card--3 {
		transform: rotate(0deg) translate(0px, 0px);
		z-index: 4;
	}
	.dept-card--4 {
		transform: rotate(6deg) translate(-18px, 10px);
		z-index: 5;
	}
	.dept-card--5 {
		transform: rotate(12deg) translate(-45px, 38px);
		z-index: 6;
	}
	.dept-card--6 {
		transform: rotate(18deg) translate(-80px, 95px);
		z-index: 7;
	}

	.dept-card-name {
		font-family: var(--font-main);
		font-size: var(--font-lg);
		font-weight: 700;
		line-height: 110%;
		letter-spacing: 0.01em;
	}

	.dept-card-desc {
		font-family: var(--font-small);
		font-size: var(--font-sm);
		font-weight: 400;
		color: rgba(255, 255, 255, 0.55);
		line-height: 130%;
	}

	.dept-card-inner {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 16px;
		z-index: 2;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	/* === Footer text === */
	.dept-footer-text {
		font-family: var(--font-small);
		font-size: var(--font-md);
		font-weight: 600;
		line-height: 180%;
		opacity: 0.65;
		color: var(--black);
		text-align: center;
		max-width: 500px;
	}

	/* === Responsive === */
	@media (max-width: 1199px) {
		.dept-card {
			width: 155px;
			height: 155px;
		}
		.dept-card-name {
			font-size: var(--font-base);
		}
		.dept-card-desc {
			font-size: 11px;
		}
	}

	@media (max-width: 991px) {
		.dept-card {
			width: 150px;
			height: 150px;
		}
		.dept-card-name {
			font-size: var(--font-sm);
		}
		.dept-card-desc {
			font-size: 10px;
		}
		.dept-card-inner {
			padding: 10px;
			gap: 3px;
		}
	}

	@media (max-width: 850px) {
		.dept-header h2 {
			font-size: var(--font-3xl);
		}

		.dept-fan {
			display: grid;
			grid-template-columns: repeat(4, 140px);
			grid-template-rows: auto auto;
			justify-content: center;
			align-items: center;
			gap: 8px;
		}

		/* Row 1 — 4 cards */
		.dept-card--0 {
			grid-column: 1;
			grid-row: 1;
			transform: rotate(-9deg) translate(20px, 18px);
		}
		.dept-card--1 {
			grid-column: 2;
			grid-row: 1;
			transform: rotate(-3deg) translate(6px, 4px);
		}
		.dept-card--2 {
			grid-column: 3;
			grid-row: 1;
			transform: rotate(3deg) translate(-6px, 4px);
		}
		.dept-card--3 {
			grid-column: 4;
			grid-row: 1;
			transform: rotate(9deg) translate(-20px, 18px);
		}

		/* Row 2 — 3 cards centered: span columns 1-3, shift right via translate to center under 4 */
		.dept-card--4 {
			grid-column: 1;
			grid-row: 2;
			transform: rotate(-6deg) translate(90px, 12px);
		}
		.dept-card--5 {
			grid-column: 2;
			grid-row: 2;
			transform: rotate(0deg) translate(70px, 0px);
		}
		.dept-card--6 {
			grid-column: 3;
			grid-row: 2;
			transform: rotate(6deg) translate(50px, 0px);
		}

		.dept-card {
			width: 140px;
			height: 140px;
			border-radius: 16px;
		}
		.dept-card-name {
			font-size: var(--font-sm);
		}
		.dept-card-desc {
			font-size: 11px;
		}
		.dept-card-inner {
			padding: 12px;
		}
	}

	@media (max-width: 500px) {
		.dept-header h2 {
			font-size: var(--font-2xl);
		}

		.dept-fan {
			grid-template-columns: repeat(4, 90px);
			gap: 6px;
		}

		/* Row 1 */
		.dept-card--0 {
			transform: rotate(-9deg) translate(12px, 18px);
		}
		.dept-card--1 {
			transform: rotate(-3deg) translate(4px, 4px);
		}
		.dept-card--2 {
			transform: rotate(3deg) translate(-4px, 4px);
		}
		.dept-card--3 {
			transform: rotate(9deg) translate(-12px, 18px);
		}

		/* Row 2 — base 45px + rotation offsets */
		.dept-card--4 {
			transform: rotate(-6deg) translate(65px, 12px);
		}
		.dept-card--5 {
			transform: rotate(0deg) translate(45px, 0px);
		}
		.dept-card--6 {
			transform: rotate(6deg) translate(25px, 0px);
		}

		.dept-card {
			width: 90px;
			height: 90px;
			border-radius: 14px;
		}
		.dept-card-name {
			font-size: 9px;
		}
		.dept-card-desc {
			font-size: 8px;
			line-height: 1.3;
		}
		.dept-card-inner {
			padding: 8px;
			gap: 3px;
		}
	}

	@media (max-width: 380px) {
		.dept-fan {
			grid-template-columns: repeat(4, 80px);
			gap: 4px;
		}

		/* Row 1 */
		.dept-card--0 {
			transform: rotate(-9deg) translate(10px, 18px);
		}
		.dept-card--1 {
			transform: rotate(-3deg) translate(3px, 4px);
		}
		.dept-card--2 {
			transform: rotate(3deg) translate(-3px, 4px);
		}
		.dept-card--3 {
			transform: rotate(9deg) translate(-10px, 18px);
		}

		/* Row 2 — base 40px + rotation offsets */
		.dept-card--4 {
			transform: rotate(-6deg) translate(60px, 12px);
		}
		.dept-card--5 {
			transform: rotate(0deg) translate(40px, 0px);
		}
		.dept-card--6 {
			transform: rotate(6deg) translate(20px, 0px);
		}

		.dept-card {
			width: 80px;
			height: 80px;
			border-radius: 12px;
		}
		.dept-card-name {
			font-size: 9px;
		}
		.dept-card-desc {
			font-size: 8px;
		}
		.dept-card-inner {
			padding: 8px;
		}
	}
</style>
