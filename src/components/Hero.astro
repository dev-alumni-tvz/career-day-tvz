---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/career-2026-fix.svg';
---

<section class="header">
	<!-- Traveling blobs -->
	<div class="blob blob-1"></div>
	<div class="blob blob-2"></div>
	<div class="blob blob-3"></div>
	<div class="blob blob-4"></div>

	<div class="hero">
		<Image
			src={heroImage}
			alt="TVZ CareerDay 2026 datum i mjesto"
			class="date-and-place hero-animate"
		/>

		<a
			href="mailto:careerday@tvz.hr?subject=Partnerstvo%20Career%20Day"
			class="hero-animate hero-animate--delay-1"
		>
			<button>Postani partner</button>
		</a>
		<p class="hero-animate hero-animate--delay-2">Vise informacija za TVZ CareerDay 2026 dolazi uskoro!</p>
	</div>

	<div class="scroll-position">
		<div class="scroll-indicator">
			<div class="arrows">
				<svg
					width="24"
					height="12"
					viewBox="0 0 24 12"
					fill="none"
				>
					<path
						d="M2 2L12 10L22 2"
						stroke="#EAC31B"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					></path>
				</svg>
				<svg
					width="24"
					height="12"
					viewBox="0 0 24 12"
					fill="none"
				>
					<path
						d="M2 2L12 10L22 2"
						stroke="#EAC31B"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					></path>
				</svg>
			</div>
		</div>
	</div>
</section>
