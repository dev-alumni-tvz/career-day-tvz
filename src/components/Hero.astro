---
import { Image } from 'astro:assets';
import Nav from '../components/Nav.astro';
import heroImage from '../assets/images/career-2026-fix.svg';
import lumaStar from '../assets/images/lumaStar.svg';
---

<section class="header">
	<Nav />
	<!-- Traveling blobs -->
	<!-- <div class="blob blob-1"></div>
	<div class="blob blob-2"></div>
	<div class="blob blob-3"></div>
	<div class="blob blob-4"></div> -->

	<div class="hero">
		<Image
			src={heroImage}
			alt="TVZ CareerDay 2026 datum i mjesto"
			class="date-and-place hero-animate"
		/>

		<a
			href="mailto:careerday@tvz.hr?subject=Partnerstvo%20Career%20Day"
			class="hero-animate"
		>
			<button>Prijavi se!</button>
		</a>
		<p class="hero-open hero-animate">
			<Image
				src={lumaStar}
				alt="star icon"
				width={15}
				height={15}
				class="hero-luma-icon"
			/>
			Otvoreno za <strong>SVE</strong> studente grada Zagreba
		</p>
	</div>

	<div class="scroll-position">
		<div class="scroll-indicator">
			<div class="arrows">
				<svg
					width="24"
					height="12"
					viewBox="0 0 24 12"
					fill="none"
				>
					<path
						d="M2 2L12 10L22 2"
						stroke="#EAC31B"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					></path>
				</svg>
				<svg
					width="24"
					height="12"
					viewBox="0 0 24 12"
					fill="none"
				>
					<path
						d="M2 2L12 10L22 2"
						stroke="#EAC31B"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					></path>
				</svg>
			</div>
		</div>
	</div>
</section>
