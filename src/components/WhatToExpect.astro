---
import { Image } from 'astro:assets';
import imgMerch from '../assets/images/card-wheel/second-wheel.png';
import imgProfilna from '../assets/images/card-wheel/first-wheel.png';
import imgRacing from '../assets/images/card-wheel/third-wheel.png';
import imgCrowd from '../assets/images/card-wheel/fift-wheel.png';
import imgBasket from '../assets/images/card-wheel/forth-wheel.png';
---

<section class="what-to-expect">
	<!-- Top text row -->
	<div class="wte-text-row reveal-stagger">
		<div class="wte-text-box">
			<h2>TVZ MERCH</h2>
			<p class="bold">KUTAK</p>
			<p class="text">Uključi se u našu tombolu i osvoji TVZ merch! Dobitnike čekaju majice, hoodice, kape i još mnogo cool stvari.</p>
		</div>

		<div class="wte-text-box">
			<h2>PROFILNA 2.0</h2>
			<p class="bold">FOTKANJE ZA CV/LINKEDIN</p>
			<p class="text">Profesionalni portreti za tvoj LinkedIn ili CV - besplatno! Stani pred objektiv i napravi prvi dojam koji se pamti.</p>
		</div>

		<div class="wte-text-box">
			<h2>GAME ON</h2>
			<p class="bold">SIM-RACING ZONA</p>
			<p class="text">Uskoči u racing simulator, pokaži što znaš i osvoji vrijedne nagrade! Idealna prilika za odmor i druženje.</p>
		</div>
	</div>

	<!-- Cards fan -->
	<div class="wte-cards-wrapper reveal scale">
		<div
			class="wte-cards"
			id="wte-cards"
		>
			<div
				class="wte-card wte-card--left"
				data-index="0"
			>
				<span class="wte-badge wte-badge--left">CV kutak</span>
				<Image
					src={imgProfilna}
					alt="CV Kutak - profilna fotografija"
				/>
			</div>

			<div
				class="wte-card wte-card--left-mid"
				data-index="1"
			>
				<span class="wte-badge wte-badge--left">TVZ Merch</span>
				<Image
					src={imgMerch}
					alt="TVZ Merch kutak"
				/>
			</div>

			<div
				class="wte-card wte-card--center"
				data-index="2"
			>
				<Image
					src={imgRacing}
					alt="Sim-racing zona"
				/>
				<span class="wte-badge wte-badge--center">Sim Racing</span>
			</div>

			<div
				class="wte-card wte-card--right-mid"
				data-index="3"
			>
				<span class="wte-badge wte-badge--right">Pogodi i osvoji</span>
				<Image
					src={imgBasket}
					alt="Pogodi i osvoji nagradu"
				/>
			</div>

			<div
				class="wte-card wte-card--right"
				data-index="4"
			>
				<span class="wte-badge wte-badge--right">Istraži event</span>
				<Image
					src={imgCrowd}
					alt="Događaj"
				/>
			</div>
		</div>
	</div>
</section>

<style>
	.what-to-expect {
		display: flex;
		flex-direction: column;
		background-color: var(--white);
	}

	/* === Text row === */
	.wte-text-row {
		padding: var(--padding-top-bottom) var(--padding-side-main);
		width: 100%;
		display: flex;
		align-items: stretch;
		justify-content: space-between;
		gap: 24px;
	}

	.wte-text-box {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 32px;
		border: 1px solid #e8e8e8;
		border-radius: 16px;
		background: var(--white);
		position: relative;
		transition:
			border-color 0.3s ease,
			box-shadow 0.3s ease;
	}

	.wte-text-box:hover {
		border-color: var(--primary-yellow);
		box-shadow: 0 8px 40px rgba(234, 195, 27, 0.12);
	}

	/* Number badge top-right */
	.what-to-expect h2 {
		font-family: var(--font-main);
		font-size: var(--font-2xl);
		font-weight: 700;
		color: var(--primary-yellow);
		margin-bottom: 0;
		white-space: nowrap;
		text-align: center;
	}

	.what-to-expect .bold {
		font-family: var(--font-main);
		font-weight: 600;
		font-size: var(--font-md);
		text-transform: uppercase;
		color: var(--black);
		letter-spacing: 0.08em;
		text-align: center;
	}

	.what-to-expect .text {
		font-family: var(--font-small);
		font-size: var(--font-base);
		color: var(--black);
		line-height: 1.7;
		opacity: 0.75;
		margin-top: 4px;
		text-align: center;
	}

	/* Responsive */
	@media (max-width: 850px) {
		.wte-text-row {
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 16px;
		}

		.wte-text-box {
			align-items: center;
			padding: 24px;
			max-width: 600px;
		}

		.what-to-expect .text {
			text-align: center;
		}
	}

	/* === Cards wrapper — clips overflow, adds padding so cards breathe === */
	.wte-cards-wrapper {
		padding: 0 var(--padding-side-main);
		width: 100%;
		margin-bottom: -15px;
	}

	/* === Fan container — centered === */
	.wte-cards {
		display: flex;
		align-items: flex-end;
		justify-content: center;
		position: relative;
	}

	/* === Individual cards === */
	.wte-card {
		position: relative;
		border-radius: 28px;
		overflow: hidden;
		flex-shrink: 0;
		cursor: pointer;
		transition:
			transform 0.45s cubic-bezier(0.34, 1.3, 0.64, 1),
			box-shadow 0.45s ease,
			opacity 0.45s ease,
			filter 0.45s ease;
		will-change: transform;
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
	}

	.wte-card img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		pointer-events: none;
	}

	/* Base sizes and rotations */
	.wte-card--left {
		width: 370px;
		aspect-ratio: 37 / 47;
		transform: rotate(-10deg) translate(180px, 180px);
		z-index: 1;
	}

	.wte-card--left-mid {
		width: 370px;
		aspect-ratio: 37 / 47;
		transform: rotate(-6deg) translate(80px, 80px);
		z-index: 2;
	}

	.wte-card--center {
		width: 370px;
		aspect-ratio: 37 / 47;
		transform: rotate(0deg) translate(0px, 20px);
		z-index: 3;
	}

	.wte-card--right-mid {
		width: 370px;
		aspect-ratio: 37 / 47;
		transform: rotate(6deg) translate(-80px, 80px);
		z-index: 2;
	}

	.wte-card--right {
		width: 370px;
		aspect-ratio: 37 / 47;
		transform: rotate(10deg) translate(-180px, 180px);
		z-index: 1;
	}

	/* === Badge === */
	.wte-badge {
		position: absolute;
		top: 16px;
		z-index: 10;
		background: var(--primary-yellow);
		color: var(--black);
		font-family: var(--font-main);
		font-size: var(--font-sm);
		font-weight: 700;
		padding: 5px 10px;
		border-radius: 20px;
	}

	.wte-badge--left {
		left: 16px;
	}
	.wte-badge--right {
		right: 16px;
	}

	.wte-badge--center {
		left: 50%;
		transform: translateX(-50%);
	}

	/* === Hover: hovered card lifts, preserving its rotation === */
	.wte-card--left.is-hovered {
		transform: rotate(-14deg) translate(100px, 160px) scale(1.04);
		z-index: 10;
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.35);
		filter: brightness(1.08);
		opacity: 1;
	}
	.wte-card--left-mid.is-hovered {
		transform: rotate(-6deg) translate(60px, 40px) scale(1.04);
		z-index: 10;
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.35);
		filter: brightness(1.08);
		opacity: 1;
	}
	.wte-card--center.is-hovered {
		transform: rotate(0deg) translate(0px, -10px) scale(1.04);
		z-index: 10;
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.35);
		filter: brightness(1.08);
		opacity: 1;
	}
	.wte-card--right-mid.is-hovered {
		transform: rotate(6deg) translate(-60px, 40px) scale(1.04);
		z-index: 10;
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.35);
		filter: brightness(1.08);
		opacity: 1;
	}
	.wte-card--right.is-hovered {
		transform: rotate(14deg) translate(-100px, 160px) scale(1.04);
		z-index: 10;
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.35);
		filter: brightness(1.08);
		opacity: 1;
	}

	/* Push LEFT — cards to the left of hovered move further left */
	.wte-card--left.push-left {
		transform: rotate(-14deg) translate(100px, 140px);
		box-shadow: none;
	}
	.wte-card--left-mid.push-left {
		transform: rotate(-6deg) translate(-10px, 50px);
		box-shadow: none;
	}
	.wte-card--center.push-left {
		transform: rotate(0deg) translate(-30px, 0px);
		box-shadow: none;
	}
	.wte-card--right-mid.push-left {
		transform: rotate(6deg) translate(-60px, 50px);
		box-shadow: none;
	}
	.wte-card--right.push-left {
		transform: rotate(14deg) translate(-100px, 140px);
		box-shadow: none;
	}

	/* === Push RIGHT — same dim effect === */
	.wte-card--left.push-right {
		transform: rotate(-14deg) translate(100px, 140px);
		box-shadow: none;
	}
	.wte-card--left-mid.push-right {
		transform: rotate(-6deg) translate(60px, 50px);
		box-shadow: none;
	}
	.wte-card--center.push-right {
		transform: rotate(0deg) translate(30px, 0px);
		box-shadow: none;
	}
	.wte-card--right-mid.push-right {
		transform: rotate(6deg) translate(10px, 50px);
		box-shadow: none;
	}
	.wte-card--right.push-right {
		transform: rotate(14deg) translate(-100px, 140px);
		box-shadow: none;
	}

	/* === Responsive === */
	@media (min-width: 2560px) {
		.wte-card--left {
			width: 500px;
			transform: rotate(-10deg) translate(240px, 240px);
		}
		.wte-card--left-mid {
			width: 500px;
			transform: rotate(-6deg) translate(110px, 110px);
		}
		.wte-card--center {
			width: 500px;
			transform: rotate(0deg) translate(0px, 30px);
		}
		.wte-card--right-mid {
			width: 500px;
			transform: rotate(6deg) translate(-110px, 110px);
		}
		.wte-card--right {
			width: 500px;
			transform: rotate(10deg) translate(-240px, 240px);
		}
		.wte-card--left.is-hovered {
			transform: rotate(-10deg) translate(240px, 210px) scale(1.04);
		}
		.wte-card--left-mid.is-hovered {
			transform: rotate(-6deg) translate(110px, 80px) scale(1.04);
		}
		.wte-card--center.is-hovered {
			transform: rotate(0deg) translate(0px, -15px) scale(1.04);
		}
		.wte-card--right-mid.is-hovered {
			transform: rotate(6deg) translate(-110px, 80px) scale(1.04);
		}
		.wte-card--right.is-hovered {
			transform: rotate(10deg) translate(-240px, 210px) scale(1.04);
		}
		.wte-card--left.push-left {
			transform: rotate(-10deg) translate(140px, 240px);
		}
		.wte-card--left-mid.push-left {
			transform: rotate(-6deg) translate(0px, 110px);
		}
		.wte-card--center.push-left {
			transform: rotate(0deg) translate(-50px, 30px);
		}
		.wte-card--right-mid.push-left {
			transform: rotate(6deg) translate(-160px, 110px);
		}
		.wte-card--right.push-left {
			transform: rotate(10deg) translate(-300px, 240px);
		}
		.wte-card--left.push-right {
			transform: rotate(-10deg) translate(300px, 240px);
		}
		.wte-card--left-mid.push-right {
			transform: rotate(-6deg) translate(160px, 110px);
		}
		.wte-card--center.push-right {
			transform: rotate(0deg) translate(50px, 30px);
		}
		.wte-card--right-mid.push-right {
			transform: rotate(6deg) translate(0px, 110px);
		}
		.wte-card--right.push-right {
			transform: rotate(10deg) translate(-140px, 240px);
		}
		.wte-cards {
			height: 700px;
		}
	}

	@media (max-width: 1441px) {
		.wte-card--left {
			width: 320px;
			transform: rotate(-10deg) translate(155px, 155px);
		}
		.wte-card--left-mid {
			width: 320px;
			transform: rotate(-6deg) translate(70px, 70px);
		}
		.wte-card--center {
			width: 320px;
			transform: rotate(0deg) translate(0px, 18px);
		}
		.wte-card--right-mid {
			width: 320px;
			transform: rotate(6deg) translate(-70px, 70px);
		}
		.wte-card--right {
			width: 320px;
			transform: rotate(10deg) translate(-155px, 155px);
		}
		.wte-card--left.is-hovered {
			transform: rotate(-10deg) translate(155px, 135px) scale(1.04);
		}
		.wte-card--left-mid.is-hovered {
			transform: rotate(-6deg) translate(70px, 50px) scale(1.04);
		}
		.wte-card--center.is-hovered {
			transform: rotate(0deg) translate(0px, -10px) scale(1.04);
		}
		.wte-card--right-mid.is-hovered {
			transform: rotate(6deg) translate(-70px, 50px) scale(1.04);
		}
		.wte-card--right.is-hovered {
			transform: rotate(10deg) translate(-155px, 135px) scale(1.04);
		}
		.wte-card--left.push-left {
			transform: rotate(-10deg) translate(80px, 155px);
		}
		.wte-card--left-mid.push-left {
			transform: rotate(-6deg) translate(-5px, 70px);
		}
		.wte-card--center.push-left {
			transform: rotate(0deg) translate(-30px, 0px);
		}
		.wte-card--right-mid.push-left {
			transform: rotate(6deg) translate(-100px, 70px);
		}
		.wte-card--right.push-left {
			transform: rotate(10deg) translate(-200px, 155px);
		}
		.wte-card--left.push-right {
			transform: rotate(-10deg) translate(200px, 155px);
		}
		.wte-card--left-mid.push-right {
			transform: rotate(-6deg) translate(100px, 70px);
		}
		.wte-card--center.push-right {
			transform: rotate(0deg) translate(30px, 0px);
		}
		.wte-card--right-mid.push-right {
			transform: rotate(6deg) translate(5px, 70px);
		}
		.wte-card--right.push-right {
			transform: rotate(10deg) translate(-80px, 155px);
		}
		.wte-cards {
			height: 480px;
		}
	}

	@media (max-width: 1199px) {
		.wte-card--left {
			width: 240px;
			transform: rotate(-10deg) translate(120px, 120px);
		}
		.wte-card--left-mid {
			width: 240px;
			transform: rotate(-6deg) translate(55px, 55px);
		}
		.wte-card--center {
			width: 240px;
			transform: rotate(0deg) translate(0px, 15px);
		}
		.wte-card--right-mid {
			width: 240px;
			transform: rotate(6deg) translate(-55px, 55px);
		}
		.wte-card--right {
			width: 240px;
			transform: rotate(10deg) translate(-120px, 120px);
		}
		.wte-card--left.is-hovered {
			transform: rotate(-10deg) translate(120px, 100px) scale(1.04);
		}
		.wte-card--left-mid.is-hovered {
			transform: rotate(-6deg) translate(55px, 35px) scale(1.04);
		}
		.wte-card--center.is-hovered {
			transform: rotate(0deg) translate(0px, -10px) scale(1.04);
		}
		.wte-card--right-mid.is-hovered {
			transform: rotate(6deg) translate(-55px, 35px) scale(1.04);
		}
		.wte-card--right.is-hovered {
			transform: rotate(10deg) translate(-120px, 100px) scale(1.04);
		}
		.wte-card--left.push-left {
			transform: rotate(-10deg) translate(60px, 120px);
		}
		.wte-card--left-mid.push-left {
			transform: rotate(-6deg) translate(-5px, 55px);
		}
		.wte-card--center.push-left {
			transform: rotate(0deg) translate(-25px, 0px);
		}
		.wte-card--right-mid.push-left {
			transform: rotate(6deg) translate(-80px, 55px);
		}
		.wte-card--right.push-left {
			transform: rotate(10deg) translate(-160px, 120px);
		}
		.wte-card--left.push-right {
			transform: rotate(-10deg) translate(160px, 120px);
		}
		.wte-card--left-mid.push-right {
			transform: rotate(-6deg) translate(80px, 55px);
		}
		.wte-card--center.push-right {
			transform: rotate(0deg) translate(25px, 0px);
		}
		.wte-card--right-mid.push-right {
			transform: rotate(6deg) translate(5px, 55px);
		}
		.wte-card--right.push-right {
			transform: rotate(10deg) translate(-60px, 120px);
		}
		.wte-cards {
			height: 380px;
		}
	}

	@media (max-width: 991px) {
		.wte-card--left {
			width: 220px;
			transform: rotate(-10deg) translate(90px, 90px);
		}
		.wte-card--left-mid {
			width: 220px;
			transform: rotate(-6deg) translate(40px, 40px);
		}
		.wte-card--center {
			width: 220px;
			transform: rotate(0deg) translate(0px, 12px);
		}
		.wte-card--right-mid {
			width: 220px;
			transform: rotate(6deg) translate(-40px, 40px);
		}
		.wte-card--right {
			width: 220px;
			transform: rotate(10deg) translate(-90px, 90px);
		}
		.wte-card--left.is-hovered {
			transform: rotate(-10deg) translate(90px, 70px) scale(1.04);
		}
		.wte-card--left-mid.is-hovered {
			transform: rotate(-6deg) translate(40px, 20px) scale(1.04);
		}
		.wte-card--center.is-hovered {
			transform: rotate(0deg) translate(0px, -8px) scale(1.04);
		}
		.wte-card--right-mid.is-hovered {
			transform: rotate(6deg) translate(-40px, 20px) scale(1.04);
		}
		.wte-card--right.is-hovered {
			transform: rotate(10deg) translate(-90px, 70px) scale(1.04);
		}
		.wte-card--left.push-left {
			transform: rotate(-10deg) translate(40px, 90px);
		}
		.wte-card--left-mid.push-left {
			transform: rotate(-6deg) translate(-5px, 40px);
		}
		.wte-card--center.push-left {
			transform: rotate(0deg) translate(-20px, 0px);
		}
		.wte-card--right-mid.push-left {
			transform: rotate(6deg) translate(-65px, 40px);
		}
		.wte-card--right.push-left {
			transform: rotate(10deg) translate(-120px, 90px);
		}
		.wte-card--left.push-right {
			transform: rotate(-10deg) translate(120px, 90px);
		}
		.wte-card--left-mid.push-right {
			transform: rotate(-6deg) translate(65px, 40px);
		}
		.wte-card--center.push-right {
			transform: rotate(0deg) translate(20px, 0px);
		}
		.wte-card--right-mid.push-right {
			transform: rotate(6deg) translate(5px, 40px);
		}
		.wte-card--right.push-right {
			transform: rotate(10deg) translate(-40px, 90px);
		}
		.wte-cards {
			height: 300px;
		}
	}

	@media (max-width: 850px) {
		.wte-card {
			border-radius: 14px;
		}
		.wte-text-row {
			flex-direction: column;
			gap: 16px;
		}
		.wte-card--left {
			width: 180px;
			transform: rotate(-10deg) translate(65px, 65px);
		}
		.wte-card--left-mid {
			width: 180px;
			transform: rotate(-6deg) translate(30px, 30px);
		}
		.wte-card--center {
			width: 180px;
			transform: rotate(0deg) translate(0px, 10px);
		}
		.wte-card--right-mid {
			width: 180px;
			transform: rotate(6deg) translate(-30px, 30px);
		}
		.wte-card--right {
			width: 180px;
			transform: rotate(10deg) translate(-65px, 65px);
		}
		.wte-card--left.is-hovered {
			transform: rotate(-10deg) translate(65px, 48px) scale(1.04);
		}
		.wte-card--left-mid.is-hovered {
			transform: rotate(-6deg) translate(30px, 14px) scale(1.04);
		}
		.wte-card--center.is-hovered {
			transform: rotate(0deg) translate(0px, -8px) scale(1.04);
		}
		.wte-card--right-mid.is-hovered {
			transform: rotate(6deg) translate(-30px, 14px) scale(1.04);
		}
		.wte-card--right.is-hovered {
			transform: rotate(10deg) translate(-65px, 48px) scale(1.04);
