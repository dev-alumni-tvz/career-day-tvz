<script>
	const cards = document.querySelectorAll<HTMLElement>('.wte-card');

	cards.forEach((card, i) => {
		card.addEventListener('mouseenter', () => {
			cards.forEach((other, j) => {
				other.classList.remove('is-hovered', 'push-left', 'push-right');
				if (j === i) {
					other.classList.add('is-hovered');
				} else if (j < i) {
					other.classList.add('push-left');
				} else {
					other.classList.add('push-right');
				}
			});
		});

		card.addEventListener('mouseleave', () => {
			cards.forEach((other) => {
				other.classList.remove('is-hovered', 'push-left', 'push-right');
			});
		});
	});
</script>
