---
import { Image } from 'astro:assets';
import { config } from '../data/config';
import lumaIco from '../assets/images/social/luma-ico.svg';
import instagramIco from '../assets/images/social/instagram-ico.svg';
import linkedinIco from '../assets/images/social/linkedin-ico.svg';
---

<nav class="main-nav" id="main-nav">
	<div class="social-links">
		<a href={config.social.luma} target="_blank" rel="noopener" aria-label="Lu.ma">
			<Image src={lumaIco} alt="Lu.ma ikona" width={20} height={20} />
		</a>
		<a href={config.social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
			<Image src={instagramIco} alt="Instagram ikona" width={20} height={20} />
		</a>
		<a href={config.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
			<Image src={linkedinIco} alt="LinkedIn ikona" width={20} height={20} />
		</a>
	</div>
</nav>
