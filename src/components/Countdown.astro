---
import { config } from '../data/config';
const eventDateISO = config.eventDate.toISOString();
---

<section class="countdown-container">
	<h3 class="countdown-text reveal">Četvrti CareerDay počinje za...</h3>
	<div class="countdown reveal-stagger">
		<div class="time">
			<span id="days">00</span>
			<p>Dana</p>
		</div>
		<span class="dot">:</span>
		<div class="time">
			<span id="hours">00</span>
			<p>Sati</p>
		</div>
		<span class="dot">:</span>
		<div class="time">
			<span id="minutes">00</span>
			<p>Minuta</p>
		</div>
		<span class="dot">:</span>
		<div class="time">
			<span id="seconds">00</span>
			<p>Sekundi</p>
		</div>
	</div>
</section>

<script is:inline define:vars={{ eventDateISO }}>
	const countdownDate = new Date(eventDateISO).getTime();

	function updateCountdown() {
		const distance = countdownDate - Date.now();

		if (distance < 0) {
			document.querySelector('.countdown-text').innerHTML = 'CareerDay je počeo!';
			clearInterval(timer);
			return;
		}

		document.getElementById('days').textContent = String(Math.floor(distance / 86400000)).padStart(2, '0');
		document.getElementById('hours').textContent = String(Math.floor((distance % 86400000) / 3600000)).padStart(2, '0');
		document.getElementById('minutes').textContent = String(Math.floor((distance % 3600000) / 60000)).padStart(2, '0');
		document.getElementById('seconds').textContent = String(Math.floor((distance % 60000) / 1000)).padStart(2, '0');
	}

	updateCountdown();
	const timer = setInterval(updateCountdown, 1000);
</script>
