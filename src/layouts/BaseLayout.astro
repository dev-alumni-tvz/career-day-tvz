---
import '../styles/style.css';
import '../styles/animations.css';
import '../styles/media-query.css';
import Analytics from '@vercel/analytics/astro';
import { config } from '../data/config';

const startDate = config.eventDate.toISOString();
const endDate = config.eventEndDate.toISOString();
---

<!doctype html>
<html lang="hr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<Analytics />
		<title>{config.eventName} | Sajam karijera u Zagrebu</title>

		<meta name="description" content="TVZ CareerDay 2026 okuplja studente i vodeće tvrtke. Prijavi se, upoznaj poslodavce, poslušaj CareerTalks i pronađi praksu ili posao." />
		<link rel="canonical" href={`${config.siteUrl}/`} />
		<meta name="author" content="TVZ CareerDay Team" />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="hr_HR" />
		<meta property="og:site_name" content="TVZ CareerDay" />
		<meta property="og:title" content={config.eventName} />
		<meta property="og:description" content="Sajam karijera TVZ-a: studenti, tvrtke, CareerTalks, prijave i poslovne prilike." />
		<meta property="og:url" content={`${config.siteUrl}/`} />
		<meta property="og:image" content={`${config.siteUrl}/assets/og/tvz-careerday-2026-og.jpg`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={config.eventName} />
		<meta name="twitter:description" content="Prijavi se i upoznaj poslodavce na TVZ CareerDay 2026." />
		<meta name="twitter:image" content={`${config.siteUrl}/assets/og/tvz-careerday-2026-og.jpg`} />
		<meta name="robots" content="index, follow" />

		<meta name="geo.region" content="HR-21" />
		<meta name="geo.placename" content="Zagreb" />
		<meta name="geo.position" content="45.8150;15.9819" />
		<meta name="ICBM" content="45.8150, 15.9819" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="theme-color" content="#000000" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Manrope:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Event",
			"name": config.eventName,
			"eventStatus": "https://schema.org/EventScheduled",
			"eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
			"description": "TVZ CareerDay 2026 okuplja studente i poslodavce kroz razgovore, prezentacije i prilike za praksu i posao.",
			"image": [`${config.siteUrl}/assets/og/tvz-careerday-2026-og.jpg`],
			"url": `${config.siteUrl}/`,
			"startDate": startDate,
			"endDate": endDate,
			"organizer": {
				"@type": "Organization",
				"name": "Tehničko veleučilište u Zagrebu",
				"url": "https://www.tvz.hr/"
			},
			"location": {
				"@type": "Place",
				"name": config.venue,
				"address": {
					"@type": "PostalAddress",
					"addressLocality": "Zagreb",
					"addressCountry": "HR"
				}
			}
		})} />
	</head>
	<body>
		<main class="main-container">
			<slot />
		</main>

		<script is:inline src="/javascript/scroll.js"></script>
		<script is:inline src="https://embed.lu.ma/checkout-button.js" id="luma-checkout"></script>
	</body>
</html>
