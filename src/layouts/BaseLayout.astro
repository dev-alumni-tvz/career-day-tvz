---
// src/layouts/BaseLayout.astro
import '../styles/style.css';
import '../styles/media-query.css';
---

<!doctype html>
<html lang="hr">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0"
		/>

		<title>TVZ CareerDay 2026</title>

		<meta
			name="description"
			content="TVZ CareerDay 2026 okuplja studente i vodeće tvrtke. Prijavi se, upoznaj poslodavce, poslušaj CareerTalks i pronađi praksu ili posao."
		/>
		<link
			rel="canonical"
			href="https://careerday.tvz.hr/"
		/>

		<meta
			property="og:type"
			content="website"
		/>
		<meta
			property="og:locale"
			content="hr_HR"
		/>
		<meta
			property="og:site_name"
			content="TVZ CareerDay"
		/>
		<meta
			property="og:title"
			content="TVZ CareerDay 2026"
		/>
		<meta
			property="og:description"
			content="Sajam karijera TVZ-a: studenti, tvrtke, CareerTalks, prijave i poslovne prilike."
		/>
		<meta
			property="og:url"
			content="https://careerday.tvz.hr/"
		/>
		<meta
			property="og:image"
			content="https://careerday.tvz.hr/assets/og/tvz-careerday-2026-og.jpg"
		/>
		<meta
			property="og:image:width"
			content="1200"
		/>
		<meta
			property="og:image:height"
			content="630"
		/>

		<meta
			name="twitter:card"
			content="summary_large_image"
		/>
		<meta
			name="twitter:title"
			content="TVZ CareerDay 2026"
		/>
		<meta
			name="twitter:description"
			content="Prijavi se i upoznaj poslodavce na TVZ CareerDay 2026."
		/>
		<meta
			name="twitter:image"
			content="https://careerday.tvz.hr/assets/og/tvz-careerday-2026-og.jpg"
		/>

		<link
			rel="icon"
			href="/icons/favicon.ico"
			sizes="any"
		/>
		<link
			rel="icon"
			type="image/png"
			href="/icons/favicon-32x32.png"
			sizes="32x32"
		/>
		<link
			rel="apple-touch-icon"
			href="/icons/apple-touch-icon.png"
		/>
		<meta
			name="theme-color"
			content="#000000"
		/>

		<link
			rel="preconnect"
			href="https://fonts.googleapis.com"
		/>
		<link
			rel="preconnect"
			href="https://fonts.gstatic.com"
			crossorigin
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>

		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Event",
				"name": "TVZ CareerDay 2026",
				"eventStatus": "https://schema.org/EventScheduled",
				"eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
				"description": "TVZ CareerDay 2026 okuplja studente i poslodavce kroz razgovore, prezentacije i prilike za praksu i posao.",
				"image": ["https://careerday.tvz.hr/assets/icons/favicon 64x64.jpg"],
				"url": "https://careerday.tvz.hr/",
				"organizer": {
					"@type": "Organization",
					"name": "Tehničko veleučilište u Zagrebu",
					"url": "https://www.tvz.hr/"
				},
				"location": {
					"@type": "Place",
					"name": "Dvorana Kornati",
					"address": {
						"@type": "PostalAddress",
						"addressLocality": "Zagreb",
						"addressCountry": "HR"
					}
				}
			}
		</script>
	</head>
	<body>
		<main class="main-container">
			<slot />
		</main>

		<script
			is:inline
			src="/javascript/count-down-timer.js"
		></script>
		<script
			is:inline
			id="luma-checkout"
			src="https://embed.lu.ma/checkout-button.js"
		></script>
		<script
			is:inline
			src="/javascript/carret-talks-overlay.js"
		></script>
	</body>
</html>
